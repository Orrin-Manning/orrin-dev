# Application Settings
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-64-character-hex-key-here
DEBUG=True  # Set to False in production

DATABASE_URL=postgresql+asyncpg://devuser:devpass@localhost:5432/orrin_dev

# Development Database (optional - defaults provided)
DEV_POSTGRES_USER=devuser
DEV_POSTGRES_PASSWORD=devpass
DEV_POSTGRES_DB=orrin_dev
DEV_POSTGRES_PORT=5432

# Production Database (REQUIRED - no defaults for security)
PROD_POSTGRES_USER=your_prod_user
PROD_POSTGRES_PASSWORD=your_secure_password_here
PROD_POSTGRES_DB=orrin_prod
